
{
  "entities": {
    "Student": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Student",
      "type": "object",
      "description": "Represents a student user account, including their profile information and unique registration ID used for login.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Student entity (matches Registration ID)."
        },
        "name": {
          "type": "string",
          "description": "The full name of the student."
        },
        "course": {
          "type": "string",
          "description": "The academic course the student is currently enrolled in."
        },
        "regId": {
          "type": "string",
          "description": "Unique registration ID for the student, serving as their login identifier."
        },
        "email": {
          "type": "string",
          "description": "Generated email for Auth lookup.",
          "format": "email"
        },
        "notice": {
          "type": "string",
          "description": "Administrative notes or remarks specific to this student."
        }
      },
      "required": [
        "id",
        "name",
        "course",
        "regId",
        "email"
      ]
    },
    "AdminUser": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AdminUser",
      "type": "object",
      "description": "Represents an administrator user account.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the AdminUser entity (matches Auth UID)."
        },
        "email": {
          "type": "string",
          "description": "The email address of the administrator.",
          "format": "email"
        },
        "name": {
          "type": "string",
          "description": "The full name of the administrator."
        }
      },
      "required": [
        "id",
        "email"
      ]
    },
    "UserSession": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserSession",
      "type": "object",
      "description": "Tracks active login sessions.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier (Auth UID)."
        },
        "userId": {
          "type": "string",
          "description": "Auth UID."
        },
        "userType": {
          "type": "string",
          "description": "admin or student"
        },
        "isActive": {
          "type": "boolean"
        }
      }
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/student/{regId}",
        "definition": {
          "entityName": "Student",
          "schema": {
            "$ref": "#/backend/entities/Student"
          },
          "description": "Stores student profiles indexed by their Registration ID."
        }
      },
      {
        "path": "/admins/{adminId}",
        "definition": {
          "entityName": "AdminUser",
          "schema": {
            "$ref": "#/backend/entities/AdminUser"
          },
          "description": "Stores admin profiles indexed by Auth UID."
        }
      },
      {
        "path": "/userSessions/{sessionId}",
        "definition": {
          "entityName": "UserSession",
          "description": "Tracks active sessions."
        }
      },
      {
        "path": "/student/{regId}/progress/{paperId}",
        "definition": {
          "entityName": "StudentPaperProgress",
          "description": "Tracks progress per student per paper."
        }
      }
    ]
  }
}
