
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isStudent(regId) {
      return isSignedIn() && (
        // Allow access if the email matches the record
        get(/databases/$(database)/documents/student/$(regId)).data.email == request.auth.token.email
      );
    }

    match /student/{regId} {
      allow get: if isStudent(regId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();

      match /progress/{paperId} {
        allow get, list: if isStudent(regId) || isAdmin();
        allow create, update: if isStudent(regId);
        allow delete: if isAdmin();
      }
    }

    match /admins/{adminId} {
      allow get: if (isSignedIn() && request.auth.uid == adminId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.email == "sunilsingh8896@gmail.com");
      allow update, delete: if isAdmin();
    }

    match /userSessions/{sessionId} {
      allow get, update: if (isSignedIn() && request.auth.uid == sessionId) || isAdmin();
      allow list, delete: if isAdmin();
      allow create: if isSignedIn();
    }

    match /papers/{paperId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    
    match /questionPapers/{paperId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}
