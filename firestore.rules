rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /students/{studentId} {
      allow get: if isOwner(studentId) || isAdmin();
      allow list: if isAdmin();
      allow create: if (isOwner(studentId) && request.resource.data.id == studentId) || isAdmin();
      allow update: if (isOwner(studentId) && request.resource.data.id == studentId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow get: if isOwner(adminId) || isAdmin();
      allow list: if isAdmin();
      // Allow bootstrapping for the primary admin email
      allow create: if isOwner(adminId) && (isAdmin() || request.resource.data.email == "sunilsingh8896@gmail.com");
      allow update, delete: if isAdmin();
    }

    match /userSessions/{sessionId} {
      allow get: if (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid)) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /questionPapers/{paperId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // Allow the old 'papers' collection which the current UI uses
    match /papers/{paperId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /users/{studentId}/{document=**} {
      allow get, list: if isOwner(studentId) || isAdmin();
      allow create, update: if isOwner(studentId);
      allow delete: if isOwner(studentId) || isAdmin();
    }
  }
}