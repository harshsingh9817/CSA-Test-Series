rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // A student can access their own profile if the email in the document matches their auth email
    function isStudentOwner(regId) {
      return isSignedIn() && (
        // resource.data refers to the document being read
        (resource != null && resource.data.email == request.auth.token.email) ||
        // request.resource.data refers to the document being written
        (request.resource != null && request.resource.data.email == request.auth.token.email)
      );
    }

    match /student/{regId} {
      // Allow get if it's the student themselves or an admin
      allow get: if isSignedIn() && (resource.data.email == request.auth.token.email || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();

      match /progress/{paperId} {
        // Nested progress needs access based on the parent student record logic
        // We use a simplified check here: if the student can get the parent, they can access progress
        allow get, list: if isSignedIn() && (get(/databases/$(database)/documents/student/$(regId)).data.email == request.auth.token.email || isAdmin());
        allow create, update: if isSignedIn() && get(/databases/$(database)/documents/student/$(regId)).data.email == request.auth.token.email;
        allow delete: if isAdmin();
        
        match /history/{historyId} {
           allow get, list: if isSignedIn() && (get(/databases/$(database)/documents/student/$(regId)).data.email == request.auth.token.email || isAdmin());
           allow create: if isSignedIn() && get(/databases/$(database)/documents/student/$(regId)).data.email == request.auth.token.email;
        }
      }
    }

    match /admins/{adminId} {
      allow get: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow list: if isAdmin();
      // Allow the primary admin to bootstrap themselves
      allow create: if isSignedIn() && (isAdmin() || request.resource.data.email == "sunilsingh8896@gmail.com");
      allow update, delete: if isAdmin();
    }

    match /userSessions/{sessionId} {
      // Users can manage their own session
      allow get, update: if isSignedIn() && (request.auth.uid == sessionId || isAdmin());
      // Admin can monitor everything
      allow list, delete: if isAdmin();
      allow create: if isSignedIn();
    }

    match /papers/{paperId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}